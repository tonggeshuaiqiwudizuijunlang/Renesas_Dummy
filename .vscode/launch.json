{
    // 使用 IntelliSense 了解相关属性。
    // DAPLink v2 在调试器里一般识别为 CMSIS-DAP v2。
    // 你当前 MSYS2 路径里有 gdb-multiarch.exe，没有 arm-none-eabi-gdb.exe，
    // 所以这里显式指定 gdbPath，避免 Cortex-Debug 默认去找 arm-none-eabi-gdb.exe。
    "version": "0.2.0",
    "configurations": [
        {
            "name": "DAPLink v2 - OpenOCD Attach",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/Objects/FSP_Project.axf",
            "request": "attach",
            "type": "cortex-debug",
            "servertype": "openocd",
            "gdbPath": "D:/MSYS2/mingw64/bin/gdb-multiarch.exe",
            "serverpath": "D:/MSYS2/mingw64/bin/openocd.exe",
            "configFiles": [
                "${workspaceFolder}/.vscode/openocd_ra6m5_daplink.cfg"
            ],
            "runToEntryPoint": "main",
            "rtos": "FreeRTOS",
            "liveWatch": {
                "enabled": true,
                "samplesPerSecond": 4
            },
            "showDevDebugOutput": "raw"
        },
        {
            "name": "DAPLink v2 - OpenOCD Launch",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/Objects/FSP_Project.axf",
            "request": "launch",
            "type": "cortex-debug",
            "servertype": "openocd",
            "gdbPath": "D:/MSYS2/mingw64/bin/gdb-multiarch.exe",
            "serverpath": "D:/MSYS2/mingw64/bin/openocd.exe",
            "configFiles": [
                "${workspaceFolder}/.vscode/openocd_ra6m5_daplink.cfg"
            ],
            "runToEntryPoint": "main",
            "rtos": "FreeRTOS",
            "liveWatch": {
                "enabled": true,
                "samplesPerSecond": 4
            },
            "showDevDebugOutput": "raw"
        }
    ]
}
